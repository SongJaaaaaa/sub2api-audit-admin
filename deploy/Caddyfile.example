admin.example.com {
  encode gzip zstd

  @backend path /api/* /up
  handle @backend {
    root * /var/www/sub2api-audit-admin/backend/public
    php_fastcgi unix//run/php/php8.4-fpm.sock
  }

  handle {
    root * /var/www/sub2api-audit-admin/frontend/dist
    try_files {path} /index.html
    file_server
  }
}
