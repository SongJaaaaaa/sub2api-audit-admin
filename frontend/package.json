{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:app": "node scripts/run-e2e.mjs app",
    "typecheck": "vue-tsc -b",
    "build": "vue-tsc -b && vite build",
    "app:build": "vue-tsc -b && vite build --mode app",
    "app:assets": "node scripts/render-app-assets.mjs",
    "app:sync": "pnpm run app:build && cap sync",
    "cap:add": "cap add android && cap add ios",
    "android:debug": "pnpm run app:sync && cd android && gradlew.bat assembleDebug",
    "android:release": "pnpm run app:sync && cd android && gradlew.bat assembleRelease",
    "ios:sync": "pnpm run app:sync",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.18.1",
    "capacitor-secure-storage-plugin": "0.13.0",
    "dayjs": "^1.11.21",
    "echarts": "^6.1.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.5"
  }
}
